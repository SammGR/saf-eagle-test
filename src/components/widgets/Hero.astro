---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),

  image,

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
const base = import.meta.env.BASE_URL;
const isHydroSaf = Astro.url.pathname.includes('hydro-saf');
---

<section class="relative md:-mt-[106px] not-prose" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>

    <div class="py-12 md:py-20 text-center">
      {/* LOGO SOLO EN HYDRO-SAF */}
      {
        isHydroSaf && (
          <div class="flex justify-center mb-6">
            <img
              src={`${base}/logo-hydro-saf.png`}
              alt="HYDRO-SAF"
              class="h-14 md:h-16 w-auto object-contain opacity-90 animate-fade"
            />
          </div>
        )
      }

      {
        tagline && (
          <p
            class="text-sm md:text-base text-primary font-semibold tracking-wider uppercase mb-3 animate-fade [animation-delay:0.1s]"
            set:html={tagline}
          />
        )
      }

      {
        title && (
          <h1
            class="text-5xl md:text-6xl font-bold leading-tight tracking-tight mb-6 font-heading dark:text-gray-200 animate-fade [animation-delay:0.2s]"
            set:html={title}
          />
        )
      }

      <div class="max-w-3xl mx-auto">
        {
          subtitle && (
            <p
              class="text-lg md:text-xl text-muted mb-10 dark:text-slate-300 animate-fade [animation-delay:0.3s]"
              set:html={subtitle}
            />
          )
        }

        {
          actions && (
            <div class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4 animate-fade [animation-delay:0.4s]">
              {Array.isArray(actions) ? (
                actions.map((action) => (
                  <div class="flex w-full sm:w-auto">
                    <Button {...(action || {})} class="w-full sm:mb-0" />
                  </div>
                ))
              ) : (
                <Fragment set:html={actions} />
              )}
            </div>
          )
        }
      </div>

      {content && <Fragment set:html={content} />}

      <div class="animate-fade [animation-delay:0.5s]">
        {
          image && (
            <div class="relative m-auto max-w-5xl">
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto rounded-md w-full"
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  width={1920}
                  height={1080}
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
