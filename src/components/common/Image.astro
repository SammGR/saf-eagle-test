---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';

type Props = {
  src: any;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
};

type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;

if (!props.alt) {
  throw new Error('Image alt is required');
}

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;

if (typeof _image === 'string') {
  image = {
    src: _image,
    attributes: {
      alt: props.alt,
      class: props.class,
      loading: props.loading || 'lazy',
      decoding: props.decoding || 'async',
      width: props.width,
      height: props.height,
    },
  };
} else if (_image?.src) {
  image = {
    src: _image.src,
    attributes: {
      alt: props.alt,
      class: props.class,
      loading: props.loading || 'lazy',
      decoding: props.decoding || 'async',
      width: props.width || _image.width,
      height: props.height || _image.height,
    },
  };
}
---

{
  image && (
    <img
      src={image.src}
      {...image.attributes}
    />
  )
}