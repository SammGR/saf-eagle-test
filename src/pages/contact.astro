---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Contact from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <HeroText tagline="Contact" title="Contact Us" />

  <!-- Form -->
  <Contact
    id="form"
    title="Contact Form"
    subtitle="We can help you. Please fill in the form below and we will get back to you as soon as possible."

    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name *',
      },
      {
        type: 'text',
        name: 'institution',
        label: 'Institution',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email address *',
      },
    ]}

    textarea={{
      label: 'Text message *',
    }}

    disclaimer={{
      label:
        'I accept that my data provided in the contact form is processed electronically and used for the purpose of contacting me. I am aware that I can revoke my consent at any time.',
    }}

    description="Fields marked with * are required."
  />

  <!-- Extra info -->
  <Features2
    title="We are here to help!"
    items={[
      {
        title: 'General support',
        description:
          'For general inquiries related to the project, research activities or collaboration opportunities.',
      },
      {
        title: 'Technical questions',
        description:
          'For questions about experimental setups, facilities or data analysis.',
      },
      {
        title: 'Email',
        description: 'contact@hydrosaf-project.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'University of Castilla-La Mancha (UCLM)',
        icon: 'tabler:map-pin',
      },
    ]}
  />

</Layout>