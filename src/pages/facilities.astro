---
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';

import f1 from '~/assets/images/Facilities/facilitie1.jpeg';
import f2 from '~/assets/images/Facilities/facilitie2.jpeg';
import f3 from '~/assets/images/Facilities/facilitie3.jpeg';
import f4 from '~/assets/images/Facilities/facilitie4.jpeg';
import f5 from '~/assets/images/Facilities/facilitie5.jpeg';
import f6 from '~/assets/images/Facilities/facilitie6.jpeg';
import f7 from '~/assets/images/Facilities/facilitie7.png';
import f8 from '~/assets/images/Facilities/facilitie8.jpeg';

const metadata = {
  title: 'Facilities',
};

const facilities = [
  {
    image: f1,
    title: 'Engine testing platform for steady-state testing',
    description:
      'Controlled setup for analysing engine performance, fuel consumption and emissions.',
  },
  {
    image: f2,
    title: 'AVL test bench for steady-state and transient engine testing',
    description:
      'Instrumentation for precise control and measurement of fuel flow, enabling accurate experimental analysis.',
  },
  {
    image: f3,
    title: 'Engine instrumentation and EVI system',
    description:'High-resolution sensors and EVI system for pressure, temperature and flow measurements across different engine sections.',
  },
  {
    image: f4,
    title: 'Fuel characterization laboratory',
    description:
      'Laboratory equipment for measuring density, viscosity, calorific value and other key fuel properties.',
  },
  {
    image: f5,
    title: 'Aerospace systems testing',
    description:
      'Facilities for evaluating elastomeric material behaviour and degradation, with emerging capabilities for aerospace system testing.',
  },
  {
    image: f8,
    title: 'Real-time emissions measurement system',
    description:
      'OBS-ONE system for high-precision, real-time measurement of exhaust gas emissions, enabling detailed analysis of pollutants during engine operation under transient conditions.',
  },
  {
    image: f6,
     title: 'Micro-jet engine test bench',
    description:
      'Experimental setup used to evaluate engine performance, fuel consumption and emissions under controlled laboratory conditions.',
  },
  {
  image: f7,
  title: 'Altitude simulation and environmental control system',
  description:
    'HORIBA-based test system capable of simulating altitude conditions up to 3000 m, with precise control of temperature and humidity for experimental evaluation of engine behaviour under varying atmospheric conditions.',
  },
];
---

<Layout metadata={metadata}>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">

    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4 dark:text-white">
        Experimental Facilities
      </h1>
      <p class="text-lg text-muted max-w-2xl mx-auto dark:text-slate-300">
        SAF-EAGLE experimental activities are supported by advanced laboratory
        infrastructure for fuel characterization, engine testing and emissions analysis.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {facilities.map((item) => (
        <div class="bg-white dark:bg-gray-900 rounded-xl shadow-md overflow-hidden">
          
          <Image
            src={item.image}
            alt={item.title}
            class="w-full h-56 object-cover"
            widths={[400, 768]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />

          <div class="p-5">
            <h3 class="text-lg font-semibold mb-2 dark:text-white">
              {item.title}
            </h3>
            <p class="text-sm text-muted dark:text-slate-400">
              {item.description}
            </p>
          </div>

        </div>
      ))}

    </div>

  </section>

</Layout>